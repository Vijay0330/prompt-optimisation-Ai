# ═══════════════════════════════════════════════════════════════
#  backend/.env.example
#  Copy to .env and fill in real values — NEVER commit .env
# ═══════════════════════════════════════════════════════════════

# ── Gemini AI ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── MongoDB Atlas ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=AI
MONGODB_DB_NAME=AI

# ── JWT Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────────────
# Dev: http://localhost:5173,http://localhost:3000
# Prod: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── App ──────────────────────────────────────────────────────────
ENV=development

# ── Phase 4: HuggingFace ─────────────────────────────────────────
# Token: https://huggingface.co/settings/tokens (Write access)
HF_TOKEN=your_hf_write_token
HF_USERNAME=your_hf_username
HF_MODEL_NAME=prompt-intelligence-assistant
BASE_MODEL=google/flan-t5-base
AUTO_TRAIN_THRESHOLD=100
